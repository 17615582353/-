.page{min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:30rpx}
.slider-container{width:100%;margin-bottom:30rpx}
.compare-wrapper{position:relative;width:100%;height:700rpx;border-radius:20rpx;overflow:hidden;background:#1a1a2e}
.compare-image{position:absolute;top:0;left:0;width:100%;height:100%}
.original{z-index:0}.restored{z-index:1}
.slider-line{position:absolute;top:0;width:4rpx;height:100%;background:#fff;z-index:3;transform:translateX(-50%)}
.slider-handle{position:absolute;top:50%;width:80rpx;height:80rpx;background:#fff;border-radius:50%;transform:translate(-50%,-50%);z-index:4;display:flex;align-items:center;justify-content:center;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.3)}
.handle-icon{font-size:32rpx;color:#6C63FF}
.labels{display:flex;justify-content:space-between;width:100%;margin-bottom:40rpx}
.label-original,.label-restored{font-size:26rpx;color:rgba(255,255,255,0.6)}
.btn-group{width:100%;display:flex;flex-direction:column;gap:20rpx}
.btn-back{background:rgba(255,255,255,0.1);color:#fff;border-radius:50rpx;padding:24rpx 0;text-align:center;font-size:30rpx;border:1rpx solid rgba(255,255,255,0.2)}
