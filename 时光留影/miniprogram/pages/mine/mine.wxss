.page{min-height:100vh;padding:30rpx}
.user-card{display:flex;align-items:center;gap:30rpx;margin-bottom:30rpx}
.avatar image{width:120rpx;height:120rpx;border-radius:50%;background:rgba(255,255,255,0.1)}
.user-info{flex:1;display:flex;flex-direction:column;gap:8rpx}
.nickname{font-size:34rpx;font-weight:600}
.vip-badge{font-size:22rpx;color:#FDCB6E;background:rgba(253,203,110,0.15);padding:6rpx 20rpx;border-radius:20rpx;align-self:flex-start}
.vip-badge.inactive{color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.05)}
.login-btn{background:linear-gradient(135deg,#6C63FF,#9B59B6);color:#fff;border-radius:40rpx;padding:16rpx 40rpx;font-size:26rpx;border:none}
.stats{display:flex;justify-content:space-around;padding:30rpx;background:rgba(255,255,255,0.05);border-radius:20rpx;margin-bottom:30rpx}
.stat-item{display:flex;flex-direction:column;align-items:center;gap:8rpx}
.stat-num{font-size:40rpx;font-weight:700;color:#6C63FF}
.stat-label{font-size:22rpx;color:rgba(255,255,255,0.5)}
.menu-list{padding:0}
.menu-item{display:flex;justify-content:space-between;align-items:center;padding:30rpx;border-bottom:1rpx solid rgba(255,255,255,0.05);font-size:28rpx}
.menu-item:last-child{border-bottom:none}
.arrow{font-size:36rpx;color:rgba(255,255,255,0.3)}
