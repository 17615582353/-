.page{min-height:100vh;padding:30rpx}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:30rpx}
.page-title{font-size:36rpx;font-weight:700}.page-count{font-size:24rpx;color:rgba(255,255,255,0.4)}
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;gap:20rpx}
.empty-icon{font-size:100rpx}.empty-text{font-size:28rpx;color:rgba(255,255,255,0.4);margin-bottom:20rpx}
.record-list{display:flex;flex-direction:column;gap:20rpx}
.record-item{display:flex;align-items:center;gap:24rpx;padding:20rpx;background:rgba(255,255,255,0.05);border-radius:16rpx}
.record-thumb{width:140rpx;height:140rpx;border-radius:12rpx;background:rgba(255,255,255,0.1)}
.record-info{flex:1}.record-date{font-size:28rpx;color:#FFF;display:block;margin-bottom:8rpx}
.record-effects{font-size:24rpx;color:rgba(255,255,255,0.4)}
.record-badge{width:40rpx;height:40rpx}
