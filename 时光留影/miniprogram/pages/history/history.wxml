<view class="page">
  <view class="header"><text class="page-title">修复记录</text><text class="page-count">共 {{records.length}} 张</text></view>
  <view class="empty-state" wx:if="{{records.length===0}}">
    <text class="empty-icon">📸</text><text class="empty-text">还没有修复记录</text>
    <button class="btn-primary" bindtap="goHome">去修复第一张照片</button>
  </view>
  <view class="record-list" wx:else>
    <view class="record-item" wx:for="{{records}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}">
      <image class="record-thumb" src="{{item.thumbnail}}" mode="aspectFill"></image>
      <view class="record-info"><text class="record-date">{{item.date}}</text><text class="record-effects">{{item.effects}}</text></view>
      <image class="record-badge" wx:if="{{item.isVip}}" src="/images/vip_badge.png" mode="aspectFit"></image>
    </view>
  </view>
</view>
