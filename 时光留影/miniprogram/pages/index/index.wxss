.page{min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:60rpx 40rpx}
.hero{display:flex;flex-direction:column;align-items:center;margin-bottom:60rpx}
.logo{width:160rpx;height:160rpx;margin-bottom:20rpx}
.title{font-size:52rpx;font-weight:700;color:#FFF;letter-spacing:4rpx}
.subtitle{font-size:28rpx;color:rgba(255,255,255,0.6);margin-top:12rpx}
.upload-area{width:100%;margin-bottom:60rpx}
.upload-box{width:100%;height:360rpx;border:4rpx dashed rgba(108,99,255,0.4);border-radius:30rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(108,99,255,0.05)}
.upload-box:active{border-color:#6C63FF;background:rgba(108,99,255,0.1)}
.upload-icon{width:80rpx;height:80rpx;margin-bottom:20rpx}
.upload-text{font-size:32rpx;color:#FFF;font-weight:500}
.upload-hint{font-size:24rpx;color:rgba(255,255,255,0.4);margin-top:12rpx}
.features{display:flex;justify-content:space-around;width:100%;margin-bottom:60rpx}
.feature-item{display:flex;flex-direction:column;align-items:center;gap:12rpx}
.feature-icon{font-size:48rpx}.feature-label{font-size:24rpx;color:rgba(255,255,255,0.6)}
.daily-tip{padding:20rpx 40rpx;background:rgba(255,255,255,0.05);border-radius:40rpx}
.tip-text{font-size:26rpx;color:rgba(255,255,255,0.5)}
